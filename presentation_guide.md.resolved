## 04.3 PlantUML Use Case Diagram (Detailed Architecture)
This logic-heavy version includes sub-use cases and advanced relationships (`include` and `extend`). Copy and paste this into [PlantUML.com](https://plantuml.com/use-case-diagram).

```plantuml
@startuml
left to right direction
skinparam packageStyle rectangle
skinparam roundcorner 20
skinparam Shadowing true

actor "Program Administrator" as Admin
actor "SME / Founder" as SME
actor "Investor / Fund Manager" as Investor

rectangle "SME Readiness Intelligence Platform" {
    
    package "User Governance" {
        usecase "Login & Security" as UC_Login
        usecase "Verify & Approve User Roles" as UC_Admin5
        usecase "Approve Investor Access" as UC_ApproveInv
    }

    package "Framework & Logic (Admin)" {
        usecase "Manage Questions & Pillars" as UC_Admin1
        usecase "Configure Scoring Templates" as UC_Admin2
        usecase "Set Risk Thresholds" as UC_AdminThreshold
    }

    package "Program Management" {
        usecase "Manage Accelerator Programs" as UC_Admin3
        usecase "Enroll in Readiness Program" as UC_SME1
        usecase "Monitor Cohort Progress" as UC_Monitor
    }

    package "The Assessment Engine" {
        usecase "Complete 8-Pillar Assessment" as UC_SME2
        usecase "Upload Document Proofs" as UC_Upload
        usecase "Analyze Readiness Score" as UC_SME5
        usecase "Run What-If Analysis" as UC_WhatIf
        
        UC_SME2 ..> UC_Upload : <<include>>
        UC_WhatIf ..> UC_SME5 : <<extend>>
    }

    package "Deal-Flow & Intelligence" {
        usecase "Access Deal-Flow Marketplace" as UC_Inv1
        usecase "Filter SMEs (Sector/Risk)" as UC_Inv5
        usecase "Analyze SME Risk & Growth" as UC_Inv2
        usecase "Monitor Portfolio Trends" as UC_Inv3
        usecase "Generate Batch PDF Reports" as UC_Admin4
        usecase "Download Due-Diligence Reports" as UC_Inv4
        
        UC_Inv5 ..> UC_Inv1 : <<include>>
    }

    package "Growth & Communication" {
        usecase "Track Improvement Goals" as UC_SME4
        usecase "Direct Messaging (SME-Inv)" as UC_Msg
    }
}

' Admin Connections
Admin -- UC_Admin1
Admin -- UC_Admin2
Admin -- UC_Admin3
Admin -- UC_Admin4
Admin -- UC_Admin5
Admin -- UC_AdminThreshold
Admin -- UC_Monitor

' SME Connections
SME -- UC_Login
SME -- UC_SME1
SME -- UC_SME2
SME -- UC_SME4
SME -- UC_SME5
SME -- UC_Msg

' Investor Connections
Investor -- UC_Login
Investor -- UC_ApproveInv
Investor -- UC_Inv1
Investor -- UC_Inv2
Investor -- UC_Inv3
Investor -- UC_Inv4
Investor -- UC_Msg

@enduml
```

